{
  "name": "brim-cms",
  "version": "1.0.0",
  "description": "CMS and Landing Page for BRIM KN",
  "main": "app.js",
  "scripts": {
    "start": "node app.js",
    "dev": "nodemon app.js",
    "build:css": "npx tailwindcss -i ./public/css/input.css -o ./public/css/output.css --minify",
    "watch:css": "npx tailwindcss -i ./public/css/input.css -o ./public/css/output.css --watch"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^8.7.0",
    "cors": "^2.8.6",
    "ejs": "^3.1.10",
    "express": "^4.19.2",
    "express-rate-limit": "^8.5.2",
    "express-session": "^1.18.0",
    "helmet": "^8.2.0",
    "slugify": "^1.6.6"
  },
  "devDependencies": {
    "nodemon": "^3.1.4",
    "tailwindcss": "^3.4.4"
  }
}
