<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= typeof title !== 'undefined' ? title + ' | BRIM KN' : 'BRIM KN - Badan Riset dan Intelektual Mahasantri' %></title>
    <meta name="description" content="<%= typeof meta_description !== 'undefined' && meta_description ? meta_description : 'Badan Riset dan Intelektual Mahasantri Khatamun Nabiyyin' %>">
    <link rel="icon" href="/favicon.ico" type="image/x-icon">
    <link rel="stylesheet" href="/css/output.css?v=2">
    <!-- AOS Animation CSS -->
    <link href="https://unpkg.com/aos@2.3.1/dist/aos.css" rel="stylesheet">
</head>
<body class="font-sans bg-brim-gray text-gray-800 antialiased selection:bg-brim-gold selection:text-brim-navy relative w-full">
    <div class="flex flex-col min-h-screen overflow-x-hidden w-full relative">
    <nav class="bg-brim-navy text-white shadow-lg fixed top-0 left-0 z-50 w-full">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex justify-between h-20 items-center">
                <div class="flex-shrink-0 flex items-center">
                    <a href="/" class="font-serif font-bold text-2xl tracking-wide flex items-center gap-3">
                        <img src="/logo-brim.png" alt="BRIM KN Logo" class="bg-white p-1 rounded-full drop-shadow-md" style="width: 56px; height: 56px; min-width: 56px; object-fit: contain; flex-shrink: 0;">
                        <span><span class="text-brim-gold">BRIM</span> KN</span>
                    </a>
                </div>
                <div class="hidden md:flex space-x-8 items-center">
                    <a href="/" class="hover:text-brim-gold transition font-medium">Beranda</a>
                    <a href="/#tentang" class="hover:text-brim-gold transition font-medium">Tentang Kami</a>
                    <a href="/blog" class="hover:text-brim-gold transition font-medium">Artikel</a>
                </div>
                <div class="-mr-2 flex items-center md:hidden">
                    <button type="button" class="inline-flex items-center justify-center p-2 rounded-md text-gray-200 hover:text-white hover:bg-brim-navy-dark focus:outline-none" aria-controls="mobile-menu" aria-expanded="false" onclick="document.getElementById('mobile-menu').classList.toggle('hidden')">
                        <svg class="block h-6 w-6" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
                        </svg>
                    </button>
                </div>
            </div>
        </div>
        <div class="md:hidden hidden bg-brim-navy border-t border-blue-900" id="mobile-menu">
            <div class="px-2 pt-2 pb-3 space-y-1 sm:px-3">
                <a href="/" class="block px-3 py-2 rounded-md text-base font-medium hover:text-brim-gold transition">Beranda</a>
                <a href="/#tentang" class="block px-3 py-2 rounded-md text-base font-medium hover:text-brim-gold transition">Tentang Kami</a>
                <a href="/blog" class="block px-3 py-2 rounded-md text-base font-medium hover:text-brim-gold transition">Artikel</a>
            </div>
        </div>
    </nav>
    <main class="flex-grow pt-20">
