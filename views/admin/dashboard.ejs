<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dasbor Admin | BRIM KN</title>
    <link rel="icon" href="/favicon.ico" type="image/x-icon">
    <link rel="stylesheet" href="/css/output.css?v=2">
</head>
<body class="bg-gray-50 font-sans min-h-screen flex flex-col">
    <nav class="bg-brim-navy text-white shadow-md">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex justify-between h-16 items-center">
                <div class="font-serif font-bold text-xl tracking-wide flex items-center gap-3">
                    <img src="/logo-brim.png" alt="BRIM KN Logo" class="bg-white p-1 rounded-full shadow-sm" style="width: 48px; height: 48px; min-width: 48px; object-fit: contain; flex-shrink: 0;">
                    <span><span class="text-brim-gold">BRIM</span> KN Admin</span>
                </div>
                <div class="flex items-center gap-4">
                    <a href="/admin/settings" class="text-sm text-gray-300 hover:text-white transition">Pengaturan</a>
                    <a href="/" target="_blank" class="text-sm text-gray-300 hover:text-white transition">Lihat Situs</a>
                    <a href="/admin/logout" class="bg-red-600 text-white px-4 py-1.5 rounded-md text-sm font-semibold hover:bg-red-700 transition">Keluar</a>
                </div>
            </div>
        </div>
    </nav>

    <main class="flex-grow max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10 w-full">
        <div class="flex justify-between items-center mb-8">
            <h1 class="text-3xl font-bold text-gray-800">Kelola Artikel</h1>
            <a href="/admin/posts/new" class="bg-brim-gold text-brim-navy px-5 py-2 rounded-md font-bold hover:bg-yellow-500 transition shadow-sm flex items-center gap-2">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path></svg>
                Tulis Artikel Baru
            </a>
        </div>

        <div class="bg-white rounded-lg shadow-sm border border-gray-200 overflow-hidden">
            <div class="p-6 border-b border-gray-200 flex justify-between items-center bg-gray-50">
                <h2 class="text-lg font-semibold text-gray-700">Total Artikel: <%= posts.length %></h2>
            </div>
            
            <% if (posts.length > 0) { %>
                <div class="overflow-x-auto">
                    <table class="w-full text-left border-collapse">
                        <thead>
                            <tr class="bg-gray-50 border-b border-gray-200 text-gray-600 text-sm uppercase tracking-wider">
                                <th class="p-4 font-semibold">Judul</th>
                                <th class="p-4 font-semibold">Tanggal</th>
                                <th class="p-4 font-semibold text-right">Aksi</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-gray-200">
                            <% posts.forEach(post => { %>
                                <tr class="hover:bg-gray-50 transition">
                                    <td class="p-4">
                                        <div class="font-semibold text-gray-800 mb-1"><%= post.title %></div>
                                        <div class="text-xs text-gray-500">/<%= post.slug %></div>
                                    </td>
                                    <td class="p-4 text-gray-600 text-sm">
                                        <%= new Date(post.created_at).toLocaleDateString('id-ID') %>
                                    </td>
                                    <td class="p-4 text-right space-x-2">
                                        <a href="/admin/posts/<%= post.id %>/edit" class="inline-flex items-center text-blue-600 hover:text-blue-800 text-sm font-medium">Edit</a>
                                        <span class="text-gray-300">|</span>
                                        <form action="/admin/posts/<%= post.id %>/delete" method="POST" class="inline-block" onsubmit="return confirm('Yakin ingin menghapus artikel ini?');">
                                            <button type="submit" class="text-red-600 hover:text-red-800 text-sm font-medium">Hapus</button>
                                        </form>
                                    </td>
                                </tr>
                            <% }) %>
                        </tbody>
                    </table>
                </div>
            <% } else { %>
                <div class="p-12 text-center text-gray-500">
                    <p>Belum ada artikel. Silakan buat artikel pertama Anda.</p>
                </div>
            <% } %>
        </div>
    </main>
</body>
</html>
