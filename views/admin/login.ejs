<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login Admin | BRIM KN</title>
    <link rel="icon" href="/favicon.ico" type="image/x-icon">
    <link rel="stylesheet" href="/css/output.css?v=2">
</head>
<body class="bg-brim-gray font-sans flex items-center justify-center min-h-screen">
    <div class="max-w-md w-full bg-white rounded-xl shadow-lg p-8 border border-gray-100">
        <div class="text-center mb-8">
            <img src="/logo-brim.png" alt="BRIM KN Logo" class="mx-auto mb-4 drop-shadow-md" style="width: 64px; height: 64px; min-width: 64px; object-fit: contain; flex-shrink: 0;">
            <h1 class="text-3xl font-serif font-bold text-brim-navy mb-2"><span class="text-brim-gold">BRIM</span> KN</h1>
            <p class="text-gray-500">Masuk ke Dasbor Admin</p>
        </div>

        <% if (error) { %>
            <div class="bg-red-50 text-red-600 p-3 rounded-md mb-6 text-sm border border-red-200">
                <%= error %>
            </div>
        <% } %>

        <form action="/admin/login" method="POST" class="space-y-6">
            <div>
                <label for="username" class="block text-sm font-medium text-gray-700 mb-1">Nama Pengguna</label>
                <input type="text" id="username" name="username" required class="w-full px-4 py-2 border border-gray-300 rounded-md focus:ring-brim-navy focus:border-brim-navy">
            </div>
            <div>
                <label for="password" class="block text-sm font-medium text-gray-700 mb-1">Kata Sandi</label>
                <input type="password" id="password" name="password" required class="w-full px-4 py-2 border border-gray-300 rounded-md focus:ring-brim-navy focus:border-brim-navy">
            </div>
            <button type="submit" class="w-full bg-brim-navy text-white py-2 px-4 rounded-md font-semibold hover:bg-blue-900 transition shadow-md">
                Masuk
            </button>
        </form>
        <div class="mt-6 text-center">
            <a href="/" class="text-sm text-gray-500 hover:text-brim-gold transition">Kembali ke Beranda</a>
        </div>
    </div>
</body>
</html>
