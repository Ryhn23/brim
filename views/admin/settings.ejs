<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Pengaturan | Admin BRIM KN</title>
    <link rel="icon" href="/favicon.ico" type="image/x-icon">
    <link rel="stylesheet" href="/css/output.css?v=2">
</head>
<body class="bg-gray-50 font-sans min-h-screen flex flex-col">
    <nav class="bg-brim-navy text-white shadow-md">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex justify-between h-16 items-center">
                <div class="font-serif font-bold text-xl tracking-wide flex items-center gap-3">
                    <img src="/logo-brim.png" alt="BRIM KN Logo" class="bg-white p-1 rounded-full shadow-sm" style="width: 48px; height: 48px; min-width: 48px; object-fit: contain; flex-shrink: 0;">
                    <span><span class="text-brim-gold">BRIM</span> KN Admin</span>
                </div>
                <div class="flex items-center gap-4">
                    <a href="/admin" class="text-sm text-gray-300 hover:text-white transition">Kembali ke Dasbor</a>
                </div>
            </div>
        </div>
    </nav>

    <main class="flex-grow max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-10 w-full">
        <h1 class="text-3xl font-bold text-gray-800 mb-8">Pengaturan Akun</h1>

        <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-8">
            <h2 class="text-xl font-bold text-brim-navy mb-6">Ganti Password</h2>
            
            <% if (error) { %>
                <div class="bg-red-50 text-red-700 p-4 rounded-md mb-6 border border-red-200">
                    <%= error %>
                </div>
            <% } %>

            <% if (success) { %>
                <div class="bg-green-50 text-green-700 p-4 rounded-md mb-6 border border-green-200">
                    <%= success %>
                </div>
            <% } %>

            <form action="/admin/settings/password" method="POST">
                <div class="mb-5">
                    <label for="current_password" class="block text-sm font-semibold text-gray-700 mb-2">Password Saat Ini</label>
                    <input type="password" id="current_password" name="current_password" required class="w-full px-4 py-2 border border-gray-300 rounded-md focus:ring-brim-navy focus:border-brim-navy">
                </div>

                <div class="mb-5">
                    <label for="new_password" class="block text-sm font-semibold text-gray-700 mb-2">Password Baru</label>
                    <input type="password" id="new_password" name="new_password" required minlength="6" class="w-full px-4 py-2 border border-gray-300 rounded-md focus:ring-brim-navy focus:border-brim-navy">
                </div>

                <div class="mb-8">
                    <label for="confirm_password" class="block text-sm font-semibold text-gray-700 mb-2">Konfirmasi Password Baru</label>
                    <input type="password" id="confirm_password" name="confirm_password" required minlength="6" class="w-full px-4 py-2 border border-gray-300 rounded-md focus:ring-brim-navy focus:border-brim-navy">
                </div>

                <div class="flex justify-end">
                    <button type="submit" class="bg-brim-navy text-white px-8 py-2 rounded-md font-bold hover:bg-blue-900 transition shadow-md">
                        Simpan Password Baru
                    </button>
                </div>
            </form>
        </div>
    </main>
</body>
</html>
