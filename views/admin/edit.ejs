<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= post ? 'Edit Artikel' : 'Tulis Artikel' %> | Admin BRIM KN</title>
    <link rel="icon" href="/favicon.ico" type="image/x-icon">
    <link rel="stylesheet" href="/css/output.css?v=2">
    <!-- Quill CSS -->
    <link href="https://cdn.quilljs.com/1.3.6/quill.snow.css" rel="stylesheet">
    <style>
        .ql-editor { min-height: 400px; font-size: 16px; font-family: 'Inter', sans-serif; }
    </style>
</head>
<body class="bg-gray-50 font-sans min-h-screen flex flex-col">
    <nav class="bg-brim-navy text-white shadow-md">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex justify-between h-16 items-center">
                <div class="font-serif font-bold text-xl tracking-wide flex items-center gap-3">
                    <img src="/logo-brim.png" alt="BRIM KN Logo" class="bg-white p-1 rounded-full shadow-sm" style="width: 48px; height: 48px; min-width: 48px; object-fit: contain; flex-shrink: 0;">
                    <span><span class="text-brim-gold">BRIM</span> KN Admin</span>
                </div>
                <div class="flex items-center gap-4">
                    <a href="/admin" class="text-sm text-gray-300 hover:text-white transition">Kembali ke Dasbor</a>
                </div>
            </div>
        </div>
    </nav>

    <main class="flex-grow max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10 w-full">
        <h1 class="text-3xl font-bold text-gray-800 mb-8"><%= post ? 'Edit Artikel' : 'Tulis Artikel Baru' %></h1>

        <form action="<%= post ? '/admin/posts/' + post.id : '/admin/posts' %>" method="POST" class="bg-white rounded-lg shadow-sm border border-gray-200 p-8" id="postForm">
            <div class="mb-6">
                <label for="title" class="block text-sm font-semibold text-gray-700 mb-2">Judul Artikel</label>
                <input type="text" id="title" name="title" value="<%= post ? post.title : '' %>" required class="w-full px-4 py-2 border border-gray-300 rounded-md focus:ring-brim-navy focus:border-brim-navy text-lg">
            </div>

            <div class="mb-6">
                <label for="meta_description" class="block text-sm font-semibold text-gray-700 mb-2">Deskripsi Meta (SEO) <span class="text-gray-400 font-normal">- Opsional, max 160 karakter</span></label>
                <textarea id="meta_description" name="meta_description" rows="2" class="w-full px-4 py-2 border border-gray-300 rounded-md focus:ring-brim-navy focus:border-brim-navy"><%= post ? post.meta_description : '' %></textarea>
            </div>

            <div class="mb-8">
                <label class="block text-sm font-semibold text-gray-700 mb-2">Konten Artikel</label>
                <div class="bg-white border border-gray-300 rounded-md overflow-hidden">
                    <div id="editor"><%- post ? post.content : '' %></div>
                </div>
                <input type="hidden" id="content" name="content">
            </div>

            <div class="flex justify-end gap-4 border-t border-gray-100 pt-6">
                <a href="/admin" class="px-6 py-2 border border-gray-300 rounded-md text-gray-700 font-medium hover:bg-gray-50 transition">Batal</a>
                <button type="submit" class="bg-brim-navy text-white px-8 py-2 rounded-md font-bold hover:bg-blue-900 transition shadow-md">
                    <%= post ? 'Simpan Perubahan' : 'Publikasikan' %>
                </button>
            </div>
        </form>
    </main>

    <!-- Quill JS -->
    <script src="https://cdn.quilljs.com/1.3.6/quill.min.js"></script>
    <script>
        var quill = new Quill('#editor', {
            theme: 'snow',
            modules: {
                toolbar: [
                    [{ 'header': [1, 2, 3, false] }],
                    ['bold', 'italic', 'underline', 'strike'],
                    ['blockquote', 'code-block'],
                    [{ 'list': 'ordered'}, { 'list': 'bullet' }],
                    [{ 'script': 'sub'}, { 'script': 'super' }],
                    [{ 'indent': '-1'}, { 'indent': '+1' }],
                    ['link', 'image', 'video'],
                    ['clean']
                ]
            }
        });

        document.getElementById('postForm').onsubmit = function() {
            var content = document.querySelector('input[name=content]');
            content.value = quill.root.innerHTML;
        };
    </script>
</body>
</html>
